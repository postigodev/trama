{
  "name": "trama",
  "version": "0.0.1",
  "description": "An open-source, local-first adaptive queue engine for music sessions",
  "private": true,
  "type": "module",
  "pnpm": {
    "overrides": {
      "typescript": "^5.3.0"
    }
  },
  "scripts": {
    "dev": "corepack pnpm -C apps/desktop dev",
    "build": "corepack pnpm -r build",
    "test": "corepack pnpm -r test",
    "lint": "corepack pnpm -r lint",
    "typecheck": "corepack pnpm -r typecheck",
    "clean": "corepack pnpm -r clean",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "keywords": [
    "music",
    "queue",
    "recommendations",
    "session-aware",
    "adaptive",
    "spotify",
    "local-first"
  ],
  "author": "postigodev",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "vitest": "^1.6.1"
  }
}
