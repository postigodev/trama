{
  "name": "trama",
  "version": "0.0.1",
  "description": "An open-source, local-first adaptive queue engine for music sessions",
  "private": true,
  "type": "module",
  "pnpm": {
    "overrides": {
      "typescript": "^5.3.0"
    }
  },
  "scripts": {
    "dev": "pnpm -C apps/desktop dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "format": "prettier --write ."
  },
  "keywords": [
    "music",
    "queue",
    "recommendations",
    "session-aware",
    "adaptive",
    "spotify",
    "local-first"
  ],
  "author": "postigodev",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
