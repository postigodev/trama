{
  "name": "@trama/desktop",
  "version": "0.0.1",
  "description": "Trama desktop companion app (Tauri + React)",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "dev": "tauri dev",
    "build:web": "vite build",
    "build": "tsc && tauri build",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "trama",
    "desktop",
    "tauri",
    "react"
  ],
  "author": "postigodev",
  "license": "MIT",
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@trama/core": "workspace:*",
    "@trama/db": "workspace:*",
    "@trama/demo-fixtures": "workspace:*",
    "@trama/shared": "workspace:*",
    "@trama/spotify-adapter": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^1.5.0",
    "@tauri-apps/cli": "^1.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
